# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

/.claude
# usau-scraper IS tracked — its own usau-scraper/.gitignore handles secrets
# (.env*, supabase/.temp/), logs, node_modules, and generated CSVs.

/design-reference
# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Supabase CLI transient cache
supabase/.temp/

# Deno lockfile — only generated as a side-effect of `deno check` when type-
# checking the usau-scraper edge functions; not part of the project (functions
# deploy from source via `supabase functions deploy`). Ignore so a stray one
# never gets committed.
deno.lock
**/deno.lock
